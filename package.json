{
  "name": "my-skin-metrix",
  "private": true,
  "description": "정확하고 개인화된 피부 분석 서비스",
  "author": "My Skin Metrix Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/ipcgrdn/myskinmetrix.git"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
